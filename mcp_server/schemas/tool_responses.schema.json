{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenStudio-MCP tool response schema (coarse)",
  "type": "object",
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "error": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "run": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ok"
  ],
  "additionalProperties": true
}
